[run]
source = app
omit =
    */tests/*
    */test_*.py
    */venv/*
    */alembic/*
    app/main.py
    app/core/logging.py
    app/core/exceptions.py
    app/tasks/*
    app/utils/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:

[html]
directory = htmlcov
